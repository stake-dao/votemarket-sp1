# Required: RPC endpoint
ETHEREUM_MAINNET_RPC_URL=https://

# Required: Contract addresses
GAUGE_CONTROLLER=0x2F50D538606Fa9EDD2B11E2446BEb18C9D5846bB
GAUGE=0x
ACCOUNT=0x

# Required for PLONK/Groth16 proofs: Succinct Prover Network
# Get PROVE tokens at https://network.succinct.xyz/
NETWORK_PRIVATE_KEY=

# Optional: Blockchain settings (defaults shown)
# CHAIN_ID=1              # Defaults to mainnet
# BLOCK_NUMBER=           # Defaults to latest block
# EPOCH=                  # Defaults to computed from block timestamp
# PROTOCOL=curve          # Defaults to curve (curve | balancer | frax | fxn | pendle | yb)

# Optional: Storage slots (auto-detected for known protocols)
# WEIGHT_MAPPING_SLOT=0x
# LAST_VOTE_MAPPING_SLOT=0x
# USER_SLOPE_MAPPING_SLOT=0x
